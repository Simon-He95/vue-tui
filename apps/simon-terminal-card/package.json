{
  "name": "@simon_he/terminal-card",
  "version": "0.1.1",
  "description": "Simon He's terminal profile card powered by vue-tui",
  "license": "MIT",
  "author": "Simon He",
  "bin": {
    "terminal-card": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "e2e": "pnpm run build && tsx test/e2e.ts",
    "pack:local": "pnpm pack --pack-destination .release"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^18.19.130",
    "tsdown": "^0.9.9",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vue": "^3.5.38"
  },
  "engines": {
    "node": ">=18"
  }
}
