{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,
    "lib": ["ES2022", "ES2022.Intl", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@simon_he/vue-tui": ["src/index.ts"],
      "@simon_he/vue-tui/core": ["src/core.ts"],
      "@simon_he/vue-tui/runtime": ["src/runtime.ts"],
      "@simon_he/vue-tui/renderer/dom": ["src/renderer-dom.ts"],
      "@simon_he/vue-tui/observability": ["src/observability.ts"],
      "@simon_he/vue-tui/vue": ["src/vue.ts"],
      "@simon_he/vue-tui/cli": ["src/cli.ts"],
      "@simon_he/vue-tui/markdown": ["src/markdown.ts"],
      "@simon_he/vue-tui/experimental": ["src/experimental.ts"],
      "@simon_he/vue-tui/experimental/video/node": ["src/experimental/video/node.ts"],
      "@simon_he/vue-tui/experimental/3d/bun": ["src/experimental/3d/bun.ts"],
      "@simon_he/vue-tui/agent": ["src/agent.ts"],
      "@simon_he/vue-tui/agent/mermaid": ["src/agent/mermaid.ts"],
      "@simon_he/vue-tui/mermaid": ["src/mermaid.ts"]
    }
  },
  "include": ["src", "test"],
  "exclude": ["examples", "dist", "node_modules", "test/fixtures/package-types"]
}
